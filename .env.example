# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me

# Извлечение — основной путь: vLLM + NVFP4 на DGX Spark (решение PM 03.07.2026,
# весь пайплайн на семействе Qwen; см. docs/dev/modules/deploy.md)
VLLM_BASE_URL=http://localhost:8000/v1
EXTRACTION_MODEL=Qwen3.5-35B-A3B-NVFP4   # точный HF-id NVFP4-сборки уточняет задача A-01
EXTRACTION_MODEL_FALLBACK=qwen3.5:9b     # откат: Ollama, то же семейство

# Ollama (эмбеддинги + запасной рантайм извлечения)
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=qwen3-embedding:0.6b

# Claude API (синтез ответов)
ANTHROPIC_API_KEY=sk-ant-...
ANSWER_MODEL=claude-opus-4-8
