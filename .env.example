# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me
# Порты (сдвинуть при конфликте с другими контейнерами на хосте, см. `docker ps`)
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# Извлечение — основной путь: Ollama + qwen3.5:35b-a3b, int4 (решение PM 03.07.2026,
# ревизия A-01: vLLM/vllm-openai:v0.18.0-cu130 не стартует на GB10 — cuda capability
# 12.1 у образа максимум 12.0; Ollama/llama.cpp получили NVFP4 и Blackwell-ядра
# весной 2026, генерация сравнялась с vLLM (~43 ток/с) — простота важнее за сутки
# до дедлайна). Эндпоинт — OLLAMA_BASE_URL ниже (OpenAI-совместимый /v1).
EXTRACTION_MODEL=qwen3.5:35b-a3b          # ~24 ГБ, int4, см. README «Быстрый старт»
EXTRACTION_MODEL_FALLBACK=qwen3.5:9b     # облегчённый откат, то же семейство

# vLLM — запарковано (профиль `vllm`, не стартует по умолчанию; см.
# deploy/docker-compose.yml). Веса ig1/Qwen3.5-35B-A3B-NVFP4 остаются в volume
# vllm_hf_cache на случай, если тег образа обновят под GB10 (cuda capability 12.1).
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_PORT=8000
VLLM_MODEL=ig1/Qwen3.5-35B-A3B-NVFP4
VLLM_GPU_MEM_UTIL=0.85
VLLM_MAX_MODEL_LEN=131072
VLLM_MAX_NUM_SEQS=4
# HF-токен — нужен только если HF-репозиторий станет gated (сейчас не требуется)
HUGGING_FACE_HUB_TOKEN=

# Ollama — основной рантайм (эмбеддинги + извлечение)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_PORT=11434
EMBEDDING_MODEL=qwen3-embedding:0.6b

# Синтез ответов — локальный Qwen через Ollama (решение PM 03.07.2026: без Claude
# API; тот же OpenAI-совместимый эндпоинт OLLAMA_BASE_URL + /v1/chat/completions).
# ВАЖНО: qwen3.5:35b-a3b — reasoning-модель, закладывать бюджет max_tokens на
# thinking. Возврат на Claude одной строкой: ANSWER_BACKEND=anthropic + валидный ключ.
ANSWER_BACKEND=ollama
ANSWER_MODEL=qwen3.5:35b-a3b
ANTHROPIC_API_KEY=
